local MAP = require "modules.map_objects"
local HALF_PI = math.pi * 0.5

function update(self)
	local pos = go.get_position()
	local angle = math.atan2(MAP.player_position.y - pos.y, MAP.player_position.x - pos.x) + 3 * HALF_PI
	local rot = vmath.quat_rotation_x(HALF_PI) * vmath.quat_rotation_y(angle)
	go.set_rotation(rot)
end